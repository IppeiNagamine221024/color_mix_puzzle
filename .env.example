# =============================================================================
# AdMob 設定（Color Order）
# =============================================================================
# 1. AdMob コンソールで iOS / Android アプリを登録し App ID を取得
# 2. バナー・リワードの広告ユニットを作成
# 3. このファイルを .env にコピーして値を入力
# 4. EAS Build では eas env:create で production 環境に同じ変数を登録
#
# ローカル: cp .env.example .env
# EAS: https://expo.dev/accounts/wippeipy221024/projects/color-order/environment-variables

# --- App ID（app.config.ts / ネイティブビルド用。EXPO_PUBLIC 不要） ---
ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx
ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx

# --- 広告ユニット ID（ランタイム JS 用。EXPO_PUBLIC 必須） ---
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# テスト広告を強制する場合は true（未設定時は本番ユニット ID が揃っていれば本番）
# EXPO_PUBLIC_USE_TEST_ADS=true

# 本番ビルド用: 上記4つのユニット ID を設定し、以下を false に
# EXPO_PUBLIC_USE_TEST_ADS=false

# =============================================================================
# アプリ内課金（24時間遊び放題パス）
# =============================================================================
# App Store Connect / Google Play Console で consumable 商品を作成してください。
# 商品 ID（両ストア共通）: com.wippeipy221024.colororder.unlimited_play_24h
#
# - iOS: App Store Connect > アプリ内課金 > 消耗型
# - Android: Play Console > 収益化 > アプリ内商品
# - テスト: iOS は Sandbox Apple ID、Android はライセンステスター + 実機ビルド
# - Expo Go ではモック購入（即時に24時間付与）で動作確認できます
